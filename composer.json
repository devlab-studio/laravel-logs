{
    "name": "devlab-studio/laravel-logs",
    "description": "Package to manage logs in Laravel applications.",
    "keywords": [
        "Devlab",
        "laravel",
        "laravel-logs"
    ],
    "homepage": "https://github.com/devlab-studio/laravel-logs",
    "license": "MIT",
    "authors": [
        {
            "name": "Devlab",
            "email": "david.maizcurrana@dev-lab.es",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "laravel/jetstream": "^5.4",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-permission": "^6.7",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Devlab\\LaravelLogs\\": "src/",
            "Devlab\\LaravelLogs\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devlab\\LaravelLogs\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devlab\\LaravelLogs\\LaravelLogsServiceProvider"
            ],
            "aliases": {
                "LaravelLogs": "Devlab\\LaravelLogs\\Facades\\LaravelLogs"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
